# --- CONFIGURAZIONE DATABASE (MariaDB) ---
# L'indirizzo del database nel network Docker
DB_HOST=sygest-db
# L'utente amministratore del database
DB_USER=root
# La password per l'utente root (definita nel docker-compose)
DB_PASSWORD=root_pwd_sygest
# Il nome del database dove salviamo i target e i CVE
DB_NAME=progetto_sygest

# --- INTEGRAZIONE GITLAB ---
# L'indirizzo base di GitLab (usiamo quello ufficiale Cloud)
GITLAB_URL=https://gitlab.com
# Il token personale (API)
GITLAB_TOKEN=glpat--V7WgQSz7bCifA5SkykoLm86MQp1Omt1ems2Cw.01.120pm28ti
# L'ID numerico del progetto dove si vuole che vengano aperte le Issue
GITLAB_PROJECT_ID=80384958

# --- INTEGRAZIONE ZABBIX ---
# L'URL per accedere all'interfaccia web di Zabbix (usato dallo script sync)
ZABBIX_URL=http://zabbix-frontend:8080
# Credenziali di accesso predefinite di Zabbix
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix
# L'indirizzo del server Zabbix per l'invio dei dati (Zabbix Sender)
ZABBIX_SERVER=zabbix-server
# La porta standard utilizzata dal server Zabbix
ZABBIX_PORT=10051

# --- SICUREZZA API SYGEST ---
# Chiave di sicurezza per autenticare l'invio dei report da Trivy al Worker
SYGEST_API_KEY=TEST